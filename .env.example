# Copy from .env.local on the Vercel dashboard
# https://nextjs.org/learn/dashboard-app/setting-up-your-database#create-a-postgres-database
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# `openssl rand -base64 32`
AUTH_SECRET=
# Local: http://localhost:3000/api/auth — Production: https://YOUR_DOMAIN.vercel.app/api/auth
AUTH_URL=http://localhost:3000/api/auth

# Set to "true" only if you must expose GET /seed in production (not recommended).
# ALLOW_SEED=